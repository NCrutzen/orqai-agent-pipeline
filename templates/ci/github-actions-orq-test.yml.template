# DIST-07 — GitHub Actions template for CONSUMER repos.
#
# Copy this file to .github/workflows/orq-agent-test.yml in YOUR agent repo
# (the repo that owns your Orq.ai agent spec + dataset). Then configure the
# secrets and variables listed in templates/ci/README.md in this skill repo.
#
# What it does: runs `/orq-agent:test` against a deployed Orq.ai agent on
# every push/PR and fails the build if results-analyzer emits a ⚠️ regression
# marker (ITRX-04). That's the regression gate from V3.0 Phase 42.

name: orq-agent-test

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:
    inputs:
      agent_key:
        description: "Orq.ai agent key to test (overrides vars.DEFAULT_AGENT_KEY)"
        required: false
      dataset_id:
        description: "Dataset ID for the experiment (overrides vars.DEFAULT_DATASET_ID)"
        required: false

env:
  ORQ_API_KEY: ${{ secrets.ORQ_API_KEY }}
  AGENT_KEY: ${{ inputs.agent_key || vars.DEFAULT_AGENT_KEY }}
  DATASET_ID: ${{ inputs.dataset_id || vars.DEFAULT_DATASET_ID }}

jobs:
  orq-agent-test:
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: Install Claude Code
        run: npm install -g @anthropic-ai/claude-code

      - name: Install orq-agent skill
        run: npx --yes skills add NCrutzen/orqai-agent-pipeline

      - name: Run /orq-agent:test on deployed agent
        id: orq_test
        run: |
          if [ -z "$AGENT_KEY" ] || [ -z "$DATASET_ID" ]; then
            echo "::error::AGENT_KEY or DATASET_ID unset. Set vars.DEFAULT_AGENT_KEY and vars.DEFAULT_DATASET_ID, or provide inputs on workflow_dispatch."
            exit 1
          fi
          claude code \
            --headless \
            --api-key "${{ secrets.ANTHROPIC_API_KEY }}" \
            --prompt "/orq-agent:test --agent $AGENT_KEY --dataset $DATASET_ID" \
            | tee orq-test-output.txt

      - name: Fail on ITRX-04 regression
        run: |
          # results-analyzer emits ⚠️ markers on any score drop vs previous run.
          if grep -q "⚠️" orq-test-output.txt; then
            echo "::error title=Regression detected (ITRX-04)::results-analyzer flagged a regression."
            echo "Output saved to orq-test-output.txt"
            exit 1
          fi
          echo "No regressions detected."

      - name: Upload test output
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: orq-test-output
          path: orq-test-output.txt
