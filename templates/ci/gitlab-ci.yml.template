# DIST-07 — GitLab CI template for CONSUMER repos.
#
# Copy this file to .gitlab-ci.yml in YOUR agent repo (the repo that owns
# your Orq.ai agent spec + dataset). Then configure the CI/CD variables
# listed in templates/ci/README.md in this skill repo.
#
# What it does: runs `/orq-agent:test` against a deployed Orq.ai agent on
# push/MR and fails the pipeline if results-analyzer emits a ⚠️ regression
# marker (ITRX-04). That's the regression gate from V3.0 Phase 42.
#
# Required CI/CD variables (set in Settings → CI/CD → Variables, masked):
#   ORQ_API_KEY, ANTHROPIC_API_KEY
# Required (unmasked is fine):
#   AGENT_KEY, DATASET_ID

stages:
  - test

orq-agent-test:
  stage: test
  image: node:20-bullseye
  timeout: 30 minutes
  script:
    - npm install -g @anthropic-ai/claude-code
    - npx --yes skills add NCrutzen/orqai-agent-pipeline
    - |
      if [ -z "$AGENT_KEY" ] || [ -z "$DATASET_ID" ]; then
        echo "AGENT_KEY or DATASET_ID unset. Configure them as CI/CD variables."
        exit 1
      fi
    - |
      claude code \
        --headless \
        --api-key "$ANTHROPIC_API_KEY" \
        --prompt "/orq-agent:test --agent $AGENT_KEY --dataset $DATASET_ID" \
        | tee orq-test-output.txt
    - |
      # Fail on any ITRX-04 regression marker from results-analyzer.
      if grep -q "⚠️" orq-test-output.txt; then
        echo "Regression detected (ITRX-04). See orq-test-output.txt"
        exit 1
      fi
      echo "No regressions detected."
  artifacts:
    when: always
    paths:
      - orq-test-output.txt
    expire_in: 30 days
  rules:
    - if: '$CI_PIPELINE_SOURCE == "push" && $CI_COMMIT_BRANCH == "main"'
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_PIPELINE_SOURCE == "web"'
