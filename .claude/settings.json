{
  "enabledPlugins": {
    "vercel-plugin@claude-code-marketplace": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pipeline-architecture-reminder.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/learning-nudge.js"
          }
        ]
      }
    ]
  }
}
