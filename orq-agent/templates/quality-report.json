{
  "_template_meta": {
    "template": "quality-report",
    "version": "1.0",
    "description": "Quality gate report for harden pipeline. Records per-agent guardrail config, quality gate results, and production-readiness status."
  },
  "swarm_name": "{{SWARM_NAME}}",
  "generated_at": "{{TIMESTAMP}}",
  "agents": [
    {
      "agent_key": "{{AGENT_KEY}}",
      "production_ready": false,
      "guardrails": [
        {
          "evaluator": "{{EVALUATOR_NAME}}",
          "execute_on": "output",
          "sample_rate": 100,
          "severity": "high|low",
          "threshold": 0.0,
          "score": 0.0,
          "pass": false
        }
      ],
      "quality_gate": {
        "pass": false,
        "failing_evaluators": [],
        "recommendation": "{{RECOMMENDATION}}"
      }
    }
  ],
  "summary": "{{SUMMARY}}"
}
